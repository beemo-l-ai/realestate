{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node git-commit/scripts/hook-user-prompt-submit.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node git-commit/scripts/hook-post-tool-use.mjs"
          }
        ]
      }
    ]
  }
}
